ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://erp_saas:erp_saas@postgres:5432/erp_saas
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-this-in-production
TENANT_DOMAIN_SUFFIX=erp.blenkotechnologies.co.tz
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
BENCH_EXEC_MODE=docker-compose
BENCH_WORKDIR=/workspace
BENCH_COMPOSE_FILE=/workspace/docker-compose.yml
BENCH_COMPOSE_COMMAND=docker-compose
BENCH_SERVICE_NAME=backend
BENCH_ASSETS_SERVICE_NAME=frontend
BENCH_BUILD_ASSETS_AFTER_PROVISION=true
BENCH_DB_ROOT_USERNAME=root
BENCH_DB_ROOT_PASSWORD=
TENANT_TLS_SYNC_ENABLED=true
TENANT_TLS_SYNC_SCRIPT_PATH=/workspace/saas/scripts/sync_tenant_tls_routes.sh
TENANT_TLS_SYNC_TIMEOUT_SECONDS=120
TENANT_TLS_SYNC_PRIME_ON_PROVISION=true
PLATFORM_ERP_BASE_URL=https://blenko.erp.blenkotechnologies.co.tz
PLATFORM_ERP_API_KEY=
PLATFORM_ERP_API_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
BILLING_CHECKOUT_SUCCESS_URL=http://localhost:3000/onboarding?payment=success
BILLING_CHECKOUT_CANCEL_URL=http://localhost:3000/onboarding?payment=cancelled
SAAS_PUBLIC_API_BASE_URL=/api

RATE_LIMIT_STORAGE_URL=redis://redis:6379/0
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
SAAS_UI_ORIGINS=https://erp.blenkotechnologies.co.tz
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
EXPOSE_METRICS=false
EXPOSE_API_DOCS=false
EXPOSE_OPENAPI_SCHEMA=false
ALLOW_DEFAULT_BILLING_WEBHOOK=false
ALLOW_MOCK_BILLING=false
REQUIRE_STRICT_WEBHOOK_VERIFICATION=true
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_PREFIX=backups
BACKUP_S3_STRICT=false
MAILERSEND_API_KEY=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=ERP SaaS
